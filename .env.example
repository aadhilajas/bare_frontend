# Backend API base URL — baked in at Vite build time for production.
# Copy to .env.local and uncomment only what you need.
#
# Local dev (optional): Vite proxy forwards /api to localhost:8000 when unset.
# VITE_CRM_API_URL=http://localhost:8000
#
# Production (Vercel): set in project env vars, not in this file.
# VITE_CRM_API_URL=https://your-backend.example.com
